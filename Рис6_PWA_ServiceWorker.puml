@startuml
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam activity {
    BackgroundColor #7C3AED
    BorderColor #5B21B6
    FontColor white
    FontSize 11
    ArrowColor #7C3AED
    ArrowFontColor #333333
    ArrowFontSize 10
    DiamondBackgroundColor #EDE9FE
    DiamondBorderColor #7C3AED
    DiamondFontColor #333333
    DiamondFontSize 10
}

skinparam partition {
    BackgroundColor #F5F3FF
    BorderColor #7C3AED
    FontColor #5B21B6
    FontSize 13
}

skinparam note {
    BackgroundColor #F5F3FF
    BorderColor #7C3AED
    FontSize 9
}

title <size:16><b>Диаграмма жизненного цикла Service Worker\nи стратегий кэширования PWA</b></size>

|#F5F3FF| Жизненный цикл Service Worker |

start

:Загрузка приложения\n(первый визит);

:navigator.serviceWorker\n.register('/sw.js');

partition "**Фаза Install**" {
    :Событие **install**;
    :Предварительное кэширование\n(Pre-cache) статических ресурсов;
    note right
      **App Shell:**
      • HTML-оболочка
      • CSS (Tailwind)
      • JS-бандлы (Nuxt chunks)
      • Шрифты
      • Иконки PWA
    end note
    :self.skipWaiting();
}

partition "**Фаза Activate**" {
    :Событие **activate**;
    :Очистка устаревших кэшей\n(удаление старых версий);
    :clients.claim()\n(перехват запросов);
}

partition "**Фаза Fetch (перехват запросов)**" {
    :Событие **fetch**\nперехват HTTP-запроса;

    if (Тип ресурса?) then (Статика:\nCSS, JS, шрифты)
        |#EDE9FE| Стратегия: Stale-While-Revalidate |
        :Вернуть из кэша\n(мгновенный ответ);
        fork
            :Фоновый запрос\nна сервер;
            :Обновить кэш\nновой версией;
        fork again
            :Пользователь видит\nкэшированную версию;
        end fork
        note right
          Быстрый ответ из кэша,
          обновление в фоне.
          При следующем визите —
          актуальная версия.
        end note

    elseif (Изображения\nиз S3) then (Медиа:\nS3 images)
        |#EDE9FE| Стратегия: Cache-First |
        if (Есть в кэше?) then (Да)
            :Вернуть из кэша;
        else (Нет)
            :Запрос к S3;
            :Сохранить в кэш;
            :Вернуть ответ;
        endif
        note right
          Изображения неизменны
          (immutable S3 keys).
          LRU-очистка при
          превышении лимита
          хранилища (50 МБ).
        end note

    elseif (API-запросы\n/api/*) then (API:\nREST endpoints)
        |#EDE9FE| Стратегия: Network-First |
        if (Сеть доступна?) then (Онлайн)
            :Запрос к серверу;
            :Сохранить ответ\nв кэш;
            :Вернуть свежие данные;
        else (Офлайн)
            :Вернуть из кэша\n(fallback);
        endif
        note right
          Приоритет — свежие данные.
          Кэш используется
          только при отсутствии
          сети (офлайн-режим).
          Таймаут сети: 3 сек.
        end note

    else (Навигация:\nHTML-страницы)
        |#EDE9FE| Стратегия: Network-First + Offline Fallback |
        if (Сеть доступна?) then (Онлайн)
            :SSR-ответ от сервера;
        else (Офлайн)
            :Показать офлайн-страницу\n(/offline.html из pre-cache);
        endif
    endif
}

|#F5F3FF| Жизненный цикл Service Worker |

:Ожидание следующего\nсобытия fetch;

note right
  **Обновление SW:**
  При деплое новой версии
  браузер обнаруживает
  изменения в sw.js →
  install нового SW →
  activate после закрытия
  всех вкладок (или skipWaiting)
end note

stop

@enduml
