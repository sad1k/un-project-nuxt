@startuml
title Диаграмма развёртывания и инфраструктуры платформы

skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam shadowing false
skinparam nodesep 50
skinparam ranksep 50
skinparam linetype ortho

skinparam ArrowColor #6B7280
skinparam ArrowThickness 1.3

skinparam node {
  BackgroundColor #F8FAFC
  BorderColor #8B5CF6
  FontColor #111827
  RoundCorner 16
}

skinparam rectangle {
  BackgroundColor #FCFCFF
  BorderColor #8B5CF6
  FontColor #111827
  RoundCorner 14
}

skinparam artifact {
  BackgroundColor #F9FAFB
  BorderColor #CBD5E1
  FontColor #374151
  RoundCorner 10
}

skinparam database {
  BackgroundColor #F8FAFC
  BorderColor #8B5CF6
  FontColor #111827
  RoundCorner 16
}

skinparam actorStyle stickman

actor "Пользователь" as User

node "Клиентское устройство" as Client {
  artifact "Браузер\n(PWA-клиент)" as Browser
  artifact "Service Worker\nCache API / Offline" as SW
}

node "GitHub + CI/CD" as CICD {
  artifact "GitHub Actions\nLint / Typecheck / Deploy" as Actions
}

node "Vercel Edge Network" as Vercel {
  artifact "Nuxt 3 SSR\n+ Static Assets (CDN)" as SSR
  artifact "Nitro API Server\nREST / SSE / AI endpoints" as Nitro
}

database "Turso Edge DB\nSQLite + edge replicas" as Turso

node "Yandex Cloud S3\nObject Storage" as S3

node "Внешние сервисы" as External {
  artifact "Nominatim API\nгеокодирование" as Geo
  artifact "LLM API\nOpenAI-совместимый" as LLM
  artifact "Sentry\nмониторинг" as Sentry
}

' === Layout ===
User -[hidden]down- Client
Client -[hidden]down- Vercel
CICD -[hidden]down- Vercel
Vercel -[hidden]down- Turso
SSR -[hidden]right- Nitro

' === Connections ===
User --> Browser : HTTPS :443

Browser --> SSR : HTML / CSS / JS
Browser --> Nitro : REST API / SSE
SW --> Nitro : network-first
SW --> S3 : cache-first

Actions --> Vercel : auto deploy\n(push в main)

Nitro --> Turso : libSQL (HTTPS)\nDrizzle ORM
Nitro --> S3 : AWS SDK\npre-signed URL
Nitro --> Geo : HTTP
Nitro --> LLM : HTTP / SSE\n(stream: true)
Nitro --> Sentry : ошибки + метрики
SSR --> Sentry : client errors

@enduml
