digraph C4_Container {
    graph [
        rankdir=TB
        fontname="Arial"
        fontsize=12
        bgcolor="white"
        pad=0.5
        nodesep=0.6
        ranksep=0.8
        label=<<TABLE BORDER="0" CELLBORDER="0"><TR><TD><FONT FACE="Arial" POINT-SIZE="20"><B>Диаграмма архитектуры платформы WanderLog</B></FONT></TD></TR><TR><TD><FONT FACE="Arial" POINT-SIZE="14" COLOR="#666666">C4 Container Diagram</FONT></TD></TR></TABLE>>
        labelloc=t
    ]
    
    node [fontname="Arial" fontsize=10]
    edge [fontname="Arial" fontsize=9 color="#707070"]

    // Person
    user [
        shape=none
        label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
            <TR><TD><FONT POINT-SIZE="40" COLOR="#08427B">👤</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="12"><B>Путешественник</B></FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#666666">Пользователь платформы</FONT></TD></TR>
        </TABLE>>
    ]

    // ===== WanderLog System Boundary =====
    subgraph cluster_wanderlog {
        label=<<TABLE BORDER="0" CELLBORDER="0"><TR><TD><FONT FACE="Arial" POINT-SIZE="14" COLOR="#444444"><B>Платформа WanderLog</B></FONT></TD></TR><TR><TD><FONT FACE="Arial" POINT-SIZE="10" COLOR="#999999">[Software System]</FONT></TD></TR></TABLE>>
        style="dashed"
        color="#444444"
        fontname="Arial"
        bgcolor="#FAFAFA"

        // --- Client Layer ---
        subgraph cluster_client {
            label=<<FONT FACE="Arial" POINT-SIZE="11" COLOR="#666666"><B>Клиентский слой</B></FONT>>
            style="rounded,dashed"
            color="#AAAAAA"
            bgcolor="#F0F4FF"

            spa [
                shape=box style="rounded,filled" fillcolor="#438DD5" fontcolor="white" penwidth=0
                label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>SPA Клиент (PWA)</B></FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#D0E0FF">[Vue.js, Pinia, Tailwind CSS]</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#E8F0FF">Адаптивный интерфейс: карта,</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#E8F0FF">дневник, лента, чат с AI</FONT></TD></TR>
                </TABLE>>
            ]

            sw [
                shape=box style="rounded,filled" fillcolor="#438DD5" fontcolor="white" penwidth=0
                label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>Service Worker</B></FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#D0E0FF">[Workbox / Cache API]</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#E8F0FF">Кэширование, офлайн,</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#E8F0FF">push-уведомления</FONT></TD></TR>
                </TABLE>>
            ]

            maplib [
                shape=box style="rounded,filled" fillcolor="#438DD5" fontcolor="white" penwidth=0
                label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>Модуль карты</B></FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#D0E0FF">[MapLibre GL JS, Three.js]</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#E8F0FF">Интерактивная карта,</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#E8F0FF">маркеры, маршруты, 3D-глобус</FONT></TD></TR>
                </TABLE>>
            ]
        }

        // --- Server Layer ---
        subgraph cluster_server {
            label=<<FONT FACE="Arial" POINT-SIZE="11" COLOR="#666666"><B>Серверный слой</B></FONT>>
            style="rounded,dashed"
            color="#AAAAAA"
            bgcolor="#F0FFF0"

            api [
                shape=box style="rounded,filled" fillcolor="#1168BD" fontcolor="white" penwidth=0
                label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>API Server</B></FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#A0C4FF">[Nuxt.js 3 / Nitro]</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#D0E0FF">REST API, SSR, SSE-стриминг,</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#D0E0FF">валидация Zod, rate limiting</FONT></TD></TR>
                </TABLE>>
            ]

            auth [
                shape=box style="rounded,filled" fillcolor="#1168BD" fontcolor="white" penwidth=0
                label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>Auth Module</B></FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#A0C4FF">[Better Auth]</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#D0E0FF">OAuth 2.0 (GitHub, Google),</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#D0E0FF">сессии, CSRF-защита</FONT></TD></TR>
                </TABLE>>
            ]

            ai_service [
                shape=box style="rounded,filled" fillcolor="#1168BD" fontcolor="white" penwidth=0
                label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>AI Service Layer</B></FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#A0C4FF">[Node.js]</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#D0E0FF">RAG-пайплайн, промпты,</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#D0E0FF">стриминг ответов LLM</FONT></TD></TR>
                </TABLE>>
            ]
        }

        // --- Data Layer ---
        subgraph cluster_data {
            label=<<FONT FACE="Arial" POINT-SIZE="11" COLOR="#666666"><B>Слой данных</B></FONT>>
            style="rounded,dashed"
            color="#AAAAAA"
            bgcolor="#FFF8F0"

            db [
                shape=cylinder style="filled" fillcolor="#08427B" fontcolor="white" penwidth=0
                label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>База данных</B></FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#A0C4FF">[Turso / SQLite]</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#D0E0FF">Локации, логи, посты,</FONT></TD></TR>
                    <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#D0E0FF">подписки, AI-диалоги</FONT></TD></TR>
                </TABLE>>
            ]
        }
    }

    // ===== External Systems =====
    s3 [
        shape=box style="rounded,filled" fillcolor="#999999" fontcolor="white" penwidth=0
        label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
            <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>Object Storage</B></FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#E0E0E0">[Yandex Cloud S3]</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">Хранение изображений</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">и медиафайлов</FONT></TD></TR>
        </TABLE>>
    ]

    nominatim [
        shape=box style="rounded,filled" fillcolor="#999999" fontcolor="white" penwidth=0
        label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
            <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>Nominatim API</B></FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#E0E0E0">[OpenStreetMap]</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">Геокодинг,</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">поиск мест</FONT></TD></TR>
        </TABLE>>
    ]

    llm [
        shape=box style="rounded,filled" fillcolor="#999999" fontcolor="white" penwidth=0
        label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
            <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>LLM API</B></FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#E0E0E0">[OpenAI-совместимый]</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">Генерация маршрутов</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">и рекомендаций</FONT></TD></TR>
        </TABLE>>
    ]

    sentry [
        shape=box style="rounded,filled" fillcolor="#999999" fontcolor="white" penwidth=0
        label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
            <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>Sentry</B></FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#E0E0E0">[Monitoring]</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">Ошибки, performance,</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">Session Replay</FONT></TD></TR>
        </TABLE>>
    ]

    vercel [
        shape=box style="rounded,filled" fillcolor="#999999" fontcolor="white" penwidth=0
        label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
            <TR><TD><FONT FACE="Arial" POINT-SIZE="11" COLOR="white"><B>Vercel Edge Network</B></FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="8" COLOR="#E0E0E0">[Hosting / CDN / CI/CD]</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">Edge Functions,</FONT></TD></TR>
            <TR><TD><FONT FACE="Arial" POINT-SIZE="9" COLOR="#F0F0F0">автодеплой из GitHub</FONT></TD></TR>
        </TABLE>>
    ]

    // ===== Relationships =====
    // User -> Client
    user -> spa [label="  HTTPS  " style=bold color="#08427B" fontcolor="#08427B"]

    // Client internal
    spa -> sw [label="Регистрация" style=dashed color="#438DD5" fontcolor="#438DD5"]
    spa -> maplib [label="Рендеринг" style=dashed color="#438DD5" fontcolor="#438DD5"]

    // Client -> Server
    spa -> api [label="  REST API / SSE  " style=bold color="#08427B" fontcolor="#08427B"]

    // Server internal
    api -> auth [label="Аутентификация" color="#1168BD" fontcolor="#1168BD"]
    api -> ai_service [label="Запросы к AI" color="#1168BD" fontcolor="#1168BD"]

    // Server -> Data
    api -> db [label="  Drizzle ORM  " color="#08427B" fontcolor="#08427B"]
    ai_service -> db [label="Контекст RAG" style=dashed color="#08427B" fontcolor="#08427B"]

    // Server -> External
    api -> s3 [label="  AWS SDK /\n  pre-signed URL  " color="#707070" fontcolor="#555555"]
    api -> nominatim [label="  HTTP  " color="#707070" fontcolor="#555555"]
    ai_service -> llm [label="  HTTP / SSE  " color="#707070" fontcolor="#555555"]

    // Monitoring
    spa -> sentry [label="Client errors" style=dashed color="#AAAAAA" fontcolor="#999999"]
    api -> sentry [label="Server errors" style=dashed color="#AAAAAA" fontcolor="#999999"]

    // Deployment
    vercel -> api [label="Развёртывание" style=dotted color="#AAAAAA" fontcolor="#999999"]
}
