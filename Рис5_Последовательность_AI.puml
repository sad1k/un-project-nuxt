@startuml
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam sequence {
    ArrowColor #7C3AED
    ArrowFontColor #333333
    ArrowFontSize 10

    LifeLineBorderColor #7C3AED
    LifeLineBackgroundColor #EDE9FE

    ParticipantBorderColor #5B21B6
    ParticipantBackgroundColor #7C3AED
    ParticipantFontColor white
    ParticipantFontSize 12
    ParticipantPadding 10

    ActorBorderColor #7C3AED
    ActorBackgroundColor #EDE9FE
    ActorFontSize 12

    BoxBorderColor #7C3AED
    BoxBackgroundColor #F5F3FF
}

skinparam noteBorderColor #7C3AED
skinparam noteBackgroundColor #F5F3FF
skinparam noteFontSize 9

title <size:16><b>Диаграмма последовательности взаимодействия с AI-ассистентом</b></size>

actor "Пользователь" as user #EDE9FE
participant "ChatWidget\n<size:9><color:#DDDDDD>Vue-компонент</color></size>" as chat #7C3AED
participant "API Server\n<size:9><color:#DDDDDD>/api/ai/chat</color></size>" as api #7C3AED
database "Turso DB\n<size:9><color:#888888>Drizzle ORM</color></size>" as db #FFFFFF
participant "LLM API\n<size:9><color:#888888>OpenAI-совместимый</color></size>" as llm #F5F5F5

== Отправка запроса ==

user -> chat : 1. Ввод запроса:\n"Составь маршрут\nпо Стамбулу на 3 дня"
activate chat

chat -> api : 2. POST /api/ai/chat\n{ message, conversationId }
activate api

api -> db : 3. INSERT aiMessage\n(role: 'user')
activate db
return OK

api -> db : 4. SELECT aiMessages\nпо conversationId\n(история диалога)
activate db
return 5. Массив предыдущих\nсообщений диалога

== Запрос к LLM ==

api -> llm : 6. POST /v1/chat/completions\n{ system prompt,\nmessages[], stream: true }
activate llm

llm --> api : 7. SSE: data: {delta}\ndata: {delta}\n...
deactivate llm

api --> chat : 8. SSE: потоковая\nпередача токенов

note right of api
  Токены передаются
  клиенту по мере
  получения от LLM
end note

== Сохранение и отображение ==

api -> db : 9. INSERT aiMessage\n(role: 'assistant',\nfull content)
activate db
return OK
deactivate api

chat --> user : 10. Отображение маршрута:\nточки на карте + описание
deactivate chat

@enduml
